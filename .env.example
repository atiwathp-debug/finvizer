# Copy this file to .env.local and fill in your Supabase project credentials.
# .env.local is gitignored (matched by *.local) — never commit real values.
#
# If these are left unset, FinVizer runs in Mock Mode automatically:
# the UI stays fully usable with simulated auth/company/customer/document data,
# and a "Mock Mode" banner is shown. See docs/supabase-setup.md.

# Project Settings > API in your Supabase dashboard.
VITE_SUPABASE_URL=
# The "anon" / "publishable" key — safe for the browser. NEVER put the
# service_role key here or anywhere in frontend code.
VITE_SUPABASE_ANON_KEY=

# After setting these, also allow-list this app's /login and
# /reset-password URLs under Authentication > URL Configuration in the
# Supabase dashboard, or email confirmation and password-reset links won't
# redirect back correctly. See docs/supabase-setup.md section 6.
